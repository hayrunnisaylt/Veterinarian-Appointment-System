{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/", "dest": "public/home.php" },
    { "src": "/giris", "dest": "public/giris.php" },
    { "src": "/kayit_ol", "dest": "public/kayit_ol.php" },
    { "src": "/(.*).php", "dest": "public/$1.php" },
    { "src": "/(.*)", "dest": "public/$1.php" }
  ]
}